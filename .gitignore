import tkinter as tk
import random


class SnakeGame:
    WINDOW_WIDTH = 700
    WINDOW_HEIGHT = 500
    CELL_SIZE = 20
    GAME_SPEED = 90

    BG_COLOR = "#111111"
    SNAKE_COLOR = "#00ff88"
    FOOD_COLOR = "#ff3b3b"
    TEXT_COLOR = "#ffffff"
    SCORE_COLOR = "#ffd700"

    def __init__(self, root):
        self.root = root
        self.root.title("Snake Game")

        self.canvas = tk.Canvas(
            root,
            width=self.WINDOW_WIDTH,
            height=self.WINDOW_HEIGHT,
            bg=self.BG_COLOR,
            highlightthickness=0
        )
        self.canvas.pack()

        self.high_score = 0
        self.restart_button = None

        self.root.bind("<Up>", lambda e: self.change_direction("UP"))
        self.root.bind("<Down>", lambda e: self.change_direction("DOWN"))
        self.root.bind("<Left>", lambda e: self.change_direction("LEFT"))
        self.root.bind("<Right>", lambda e: self.change_direction("RIGHT"))

        self.start_game()

    def start_game(self):
        if self.restart_button:
            self.restart_button.destroy()

        self.score = 0
        self.direction = "RIGHT"

        self.snake = [
            (100, 100),
            (80, 100),
            (60, 100)
        ]

        self.spawn_food()
        self.update()

    def spawn_food(self):
        x = random.randint(0, (self.WINDOW_WIDTH // self.CELL_SIZE) - 1) * self.CELL_SIZE
        y = random.randint(0, (self.WINDOW_HEIGHT // self.CELL_SIZE) - 1) * self.CELL_SIZE
        self.food = (x, y)

    def draw(self):
        self.canvas.delete("all")

        for x, y in self.snake:
            self.canvas.create_rectangle(
                x, y,
                x + self.CELL_SIZE,
                y + self.CELL_SIZE,
                fill=self.SNAKE_COLOR,
                outline=""
            )

        fx, fy = self.food
        self.canvas.create_oval(
            fx, fy,
            fx + self.CELL_SIZE,
            fy + self.CELL_SIZE,
            fill=self.FOOD_COLOR,
            outline=""
        )

        self.canvas.create_text(
            90, 25,
            text=f"Score: {self.score}",
            fill=self.TEXT_COLOR,
            font=("Segoe UI", 14, "bold")
        )

        self.canvas.create_text(
            250, 25,
            text=f"Best: {self.high_score}",
            fill=self.SCORE_COLOR,
            font=("Segoe UI", 14, "bold")
        )

    def update(self):
        head_x, head_y = self.snake[0]

        movement = {
            "UP": (0, -self.CELL_SIZE),
            "DOWN": (0, self.CELL_SIZE),
            "LEFT": (-self.CELL_SIZE, 0),
            "RIGHT": (self.CELL_SIZE, 0)
        }

        dx, dy = movement[self.direction]
        new_head = (head_x + dx, head_y + dy)

        if self.check_collision(new_head):
            self.game_over()
            return

        self.snake.insert(0, new_head)

        if new_head == self.food:
            self.score += 1
            self.spawn_food()
        else:
            self.snake.pop()

        self.draw()
        self.root.after(self.GAME_SPEED, self.update)

    def check_collision(self, position):
        x, y = position

        return (
            x < 0 or x >= self.WINDOW_WIDTH or
            y < 0 or y >= self.WINDOW_HEIGHT or
            position in self.snake
        )

    def change_direction(self, new_direction):
        opposites = {
            "UP": "DOWN",
            "DOWN": "UP",
            "LEFT": "RIGHT",
            "RIGHT": "LEFT"
        }

        if opposites[new_direction] != self.direction:
            self.direction = new_direction

    def game_over(self):
        self.high_score = max(self.high_score, self.score)

        self.canvas.delete("all")

        self.canvas.create_text(
            self.WINDOW_WIDTH / 2,
            self.WINDOW_HEIGHT / 2 - 40,
            text="GAME OVER",
            fill=self.FOOD_COLOR,
            font=("Segoe UI", 30, "bold")
        )

        self.canvas.create_text(
            self.WINDOW_WIDTH / 2,
            self.WINDOW_HEIGHT / 2 + 10,
            text=f"Score: {self.score}   |   Best: {self.high_score}",
            fill=self.TEXT_COLOR,
            font=("Segoe UI", 16)
        )

        self.restart_button = tk.Button(
            self.root,
            text="Play Again",
            command=self.start_game,
            font=("Segoe UI", 12, "bold"),
            padx=15,
            pady=5
        )
        self.restart_button.pack(pady=15)


if __name__ == "__main__":
    root = tk.Tk()
    game = SnakeGame(root)
    root.mainloop()
